{
  "name": "ploop-backend",
  "version": "1.0.0",
  "description": "Backend API for Ploop toilet finder app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node src/migrations/run.ts",
    "import-toilets": "ts-node scripts/import-toilets-to-render.ts",
    "set-johor-bahru-bidet": "ts-node scripts/set-johor-bahru-bidet.ts",
    "backfill-city": "ts-node scripts/backfill-city.ts",
    "import-book1-pdf": "ts-node scripts/import-book1-bidet-pdf.ts",
    "import-global": "ts-node scripts/import-global-toilets.ts"
  },
  "keywords": [
    "toilet",
    "location",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "apple-signin-auth": "^1.1.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.3",
    "string-similarity": "^4.0.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.1",
    "pdf-parse": "^1.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ploop
DB_USER=postgres
DB_PASSWORD=your_password

# Server Configuration
# PORT: default 8082. Expo runs on 8081. Set EXPO_PUBLIC_PLOOP_API_URL in mobile/.env (e.g. http://YOUR_IP:8082).
NODE_ENV=development

# Scale (100K+ users)
# RATE_LIMIT_MAX=300     # requests per IP per minute (default 300)
# DB_POOL_MAX=50         # Postgres pool size per process (default 50)

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# CORS
CORS_ORIGIN=http://localhost:8081

# Google Places API (optional - for landmark search)
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Directions API (optional - for in-app routing)
# Enable "Routes API" (preferred) or "Directions API" in Google Cloud Console (billing required).
GOOGLE_DIRECTIONS_API_KEY=your_google_directions_api_key_here

# Routes API (preferred - for in-app routing)
GOOGLE_ROUTES_API_KEY=your_google_routes_api_key_here

# Auth (Google + Apple Sign-In)
JWT_SECRET=your_jwt_secret_min_32_chars_long_please
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Android OAuth client ID (for native Google Sign-In on Android; add to Render for production)
# GOOGLE_ANDROID_CLIENT_ID=1010299468013-xxx.apps.googleusercontent.com
APPLE_CLIENT_ID=your_apple_services_id
# Comma-separated emails that should have admin role (e.g. your Gmail)
ADMIN_EMAILS=rubiks.bb@gmail.com

# Monthly poop-game top 3 email (1st of month UTC, after hour below). Uses same SMTP as suggestions.
# Set ADMIN_EMAILS to include admin@ploop-app.com (or any inbox that should receive the list).
# MONTHLY_POOP_GAME_REPORT_HOUR_UTC=8
# Optional: POST /api/internal/monthly-poop-game-report with header X-Ploop-Monthly-Secret (for Render cron backup)
# MONTHLY_POOP_GAME_REPORT_SECRET=long_random_string_min_8_chars

# Suggestion box: email alerts to admin (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@ploop.app
# SMTP_SECURE=false


{
  "name": "ploop-mobile",
  "version": "1.2.15",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "postinstall": "patch-package",
    "version:bump": "node scripts/bump-version.js",
    "build:ios": "npm run version:bump && node scripts/prebuild-ios.js",
    "submit:ios": "eas submit --platform ios --latest",
    "release:ios": "node scripts/release-ios.js",
    "start": "expo start --go --port 8081",
    "android": "expo start --go --android --port 8081",
    "ios": "expo start --go --ios --port 8081",
    "web": "expo start --go --web --port 8081",
    "start:tunnel": "expo start --go --port 8081 --tunnel",
    "tunnel": "expo start --go --port 8081 --tunnel",
    "clean-ports": "node -e \"const {execSync}=require('child_process');[8081,8082].forEach(p=>{try{const pid=execSync('lsof -t -iTCP:'+p+' -sTCP:LISTEN',{encoding:'utf8'}).trim();if(pid){execSync('kill '+pid);console.log('Killed PID '+pid+' on port '+p);}}catch(e){}})\""
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "axios": "^1.6.2",
    "expo": "^54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-gaode-map": "^2.2.28",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "patch-package": "^8.0.1",
    "typescript": "^5.1.3"
  },
  "private": true
}

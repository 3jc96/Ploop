# Optional: Google Maps JavaScript API key for the web map.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here

# Gaode Web Service key for POI toilet search in China. Enable "Web服务" in Gaode console.
# Can use same key as map SDK if Web Service is enabled.
# EXPO_PUBLIC_GAODE_WEB_KEY=your_gaode_web_key

# Backend API URL. Default: Render (https://ploop-api.onrender.com).
# Use Render so you don't need to run the backend locally.
EXPO_PUBLIC_PLOOP_API_URL=https://ploop-api.onrender.com

# Local backend (optional): only if you want to develop against localhost.
# Physical device: use your Mac's LAN IP (ipconfig getifaddr en0).
# EXPO_PUBLIC_PLOOP_API_URL=http://192.168.1.5:8082
# iOS Simulator: EXPO_PUBLIC_PLOOP_USE_LOCALHOST=true

# Google Sign-In: OAuth 2.0 Web client ID (same as backend GOOGLE_CLIENT_ID). Get from Google Cloud Console.
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
